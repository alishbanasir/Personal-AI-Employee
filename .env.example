# .env.example — Copy to .env and fill in your values
# NEVER commit .env to git

# Vault path
VAULT_PATH=D:\alish-hackathon-0\AI_Employee_Vault

# Dry run mode (set to "true" during development/testing — no real posts sent)
DRY_RUN=false

# ── LinkedIn (Silver tier) ────────────────────────────────────────────────────
# Your LinkedIn login credentials (used by social_media_manager.py via Playwright)
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your_password
#
# Path where the Playwright browser session (cookies) will be saved.
# This lets subsequent runs skip the login step.
LINKEDIN_SESSION_PATH=D:\alish-hackathon-0\.linkedin_session.json

# ── Gmail API ────────────────────────────────────────────────────────────────
# Path to the OAuth2 client secrets JSON downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_PATH=D:\alish-hackathon-0\gmail_credentials.json
# Where the OAuth2 read token is saved after first login (auto-refreshed).
GMAIL_TOKEN_PATH=D:\alish-hackathon-0\.gmail_token.json
# Where the OAuth2 send token is saved — created by: python src/gmail_auth.py
GMAIL_SEND_TOKEN_PATH=D:\alish-hackathon-0\.gmail_send_token.json
# Your Gmail address shown in the From field of sent emails.
GMAIL_FROM_EMAIL=alishbanasir54@gmail.com
# How often to poll Gmail in seconds (default: 60).
GMAIL_POLL_INTERVAL=60
# Comma-separated sender email addresses that always trigger an action file.
# GMAIL_PRIORITY_SENDERS=boss@company.com,investor@vc.com
# Comma-separated subject keywords that always trigger an action file.
# GMAIL_PRIORITY_KEYWORDS=urgent,invoice,payment,action required

# ── Twitter/X API (Gold tier) ────────────────────────────────────────────────
# Create a project + app at https://developer.twitter.com/en/portal/dashboard
# Enable "Read and Write" permissions on the app, then generate tokens below.
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# ── Banking API (Gold tier) ───────────────────────────────────────────────────
# BANK_API_TOKEN=your_token
